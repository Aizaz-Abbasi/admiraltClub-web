generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int           @id @default(autoincrement())
  email            String        @unique
  password         String
  name             String
  phone            String?
  role             Role          @default(MEMBER)
  profilePicture   String?
  drivingLicense   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  age              Int?
  guestAccessUntil DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  membership       Membership?
  reservations     Reservation[]
  scorecards       Scorecard[]
  dayPasses        DayPass[]
}

model Location {
  id         Int         @id @default(autoincrement())
  name       String
  address    String
  createdAt  DateTime    @default(now())
  simulators Simulator[]
}

model Simulator {
  id           Int             @id @default(autoincrement())
  name         String
  locationId   Int
  status       SimulatorStatus @default(ACTIVE)
  createdAt    DateTime        @default(now())
  reservations Reservation[]
  location     Location        @relation(fields: [locationId], references: [id])
}

model Membership {
  id                   Int            @id @default(autoincrement())
  userId               Int            @unique
  type                 MembershipType
  status               String         @default("active")
  startDate            DateTime       @default(now())
  endDate              DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime       @default(now())
  user                 User           @relation(fields: [userId], references: [id])
}

model DayPass {
  id          Int          @id @default(autoincrement())
  userId      Int
  status      String       @default("unused") // unused | used
  bookingId   Int?
  guestUserId Int?
  stripeId    String?
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id])
  booking     Reservation? @relation(fields: [bookingId], references: [id])
}

model Reservation {
  id          Int               @id @default(autoincrement())
  userId      Int
  simulatorId Int
  startTime   DateTime
  endTime     DateTime
  doorCode    String
  status      ReservationStatus @default(BOOKED)
  createdAt   DateTime          @default(now())
  simulator   Simulator         @relation(fields: [simulatorId], references: [id])
  user        User              @relation(fields: [userId], references: [id])
  dayPasses   DayPass[]
}

model Course {
  id         Int         @id @default(autoincrement())
  name       String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  scorecards Scorecard[]
}

model Scorecard {
  id         Int      @id @default(autoincrement())
  userId     Int
  courseId   Int
  score      Int
  datePlayed DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model Payment {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Float
  type      String
  status    String
  stripeId  String?
  createdAt DateTime @default(now())
}

model AdminLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  action    String
  details   String?
  createdAt DateTime @default(now())
}

enum Role {
  MEMBER
  GUEST
  ADMIN
}

enum SimulatorStatus {
  ACTIVE
  MAINTENANCE
}

enum MembershipType {
  MONTHLY
  MONTHLY_PREMIUM
  YEARLY
  DAY_PASS
}

enum ReservationStatus {
  BOOKED
  CANCELLED
}
